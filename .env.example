# 复制这个文件为 .env，并填入真实的值（.env 不会被提交到 git，是安全的）

# 博客公开访问的网址（部署后替换为实际域名，如 https://my-blog.netlify.app）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# 数据库连接串。本地开发可以用 `npx prisma dev` 自动生成一个；
# 正式上线时去 https://neon.tech 免费创建一个 Postgres 数据库，把连接串填在这里。
DATABASE_URL=""

# 后台登录密码，自己设置一个记得住但别人猜不到的密码。
ADMIN_PASSWORD=""

# 加密后台登录会话用的随机字符串，本地终端运行 `openssl rand -base64 32` 生成一个填进来即可。
SESSION_SECRET=""

# 图片上传采用 base64 内嵌方案（直接存进数据库），不需要任何云存储服务。
